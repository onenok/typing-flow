{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "typing-flow", // 這裡可以改成你的專案名稱
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
